# Orbitaskflow environment example

# ---------------------------------
# 站点全局访问密码（部署时在 .env.local 中覆盖）
# ---------------------------------
SITE_USER=admin
SITE_PASSWORD=123456
SITE_AUTH_SECRET=your_very_long_and_secret_jwt_key_here

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=orbitaskflow
DATABASE_URL=postgres://postgres:postgres@localhost:5432/orbitaskflow?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# Application Secrets
# 32-byte hex/base64 recommended for AES-256-GCM (example value is placeholder!)
TOKEN_ENC_KEY=replace-with-strong-secret

# Logging controls (adjust per environment)
AGENT_BRIDGE_LOG_LEVEL=INFO
SITE_AUTH_LOG_LEVEL=info
